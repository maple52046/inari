# Secret used to seal the iron-session encrypted cookie holding S3 credentials.
# Must be at least 32 characters. Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Default S3 endpoint prefilled on the /connect page.
DEFAULT_S3_ENDPOINT=https://xyz.example.com

# --- Trusting a private/internal CA (preferred over skipping TLS) ---
# The dev/start scripts run Node with --use-system-ca, so the OS trust store is
# used automatically. For an internal CA (error UNABLE_TO_GET_ISSUER_CERT_LOCALLY),
# install it in the host trust store and it just works, e.g. on Debian/Ubuntu:
#   sudo cp your-ca.pem /usr/local/share/ca-certificates/your-ca.crt
#   sudo update-ca-certificates
# Fallback for a single PEM without touching the OS store (must be on the launch
# line; NOT read from this dotenv file):
#   NODE_EXTRA_CA_CERTS=/path/to/ca.pem npm run dev

# --- Cross-origin dev access (only needed when NOT using localhost) ---
# Set these when reaching the dev server via a LAN IP, domain, or reverse
# proxy, otherwise Next.js blocks cross-origin dev requests / Server Actions.
# Comma-separated. Host[:port] for dev origins; full origins for Server Actions.
# ALLOWED_DEV_ORIGINS=xyz.example.com,192.168.0.1:3000
# SERVER_ACTIONS_ALLOWED_ORIGINS=https://xyz.example.com,http://192.168.0.1:3000
