{
  "name": "s3-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--use-system-ca next dev",
    "build": "next build",
    "start": "NODE_OPTIONS=--use-system-ca next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
